  {
    "id": "MEM-1773761816728",
    "text": "Nope delete everything",
    "created_at": "2026-03-17T15:36:56.728Z"
  },
  {
    "id": "MEM-1773761834092",
    "text": "Why won’t you let me delete it?",
    "created_at": "2026-03-17T15:37:14.092Z"
  },
  {
    "id": "MEM-1773761874055",
    "text": "I’m trying to delete the project because I don’t want to build it anymore",
    "created_at": "2026-03-17T15:37:54.055Z"
  },
  {
    "id": "MEM-1773761910942",
    "text": "It was a test to see how you and the team will operate,",
    "created_at": "2026-03-17T15:38:30.942Z"
  },
  {
    "id": "MEM-1773761957637",
    "text": "Now that I understand how you think and work, I’m trying to delete this test project",
    "created_at": "2026-03-17T15:39:17.637Z"
  },
  {
    "id": "MEM-1773762049255",
    "text": "Thank you for your insight but I want to wipe the project and make sure the workers are free for future projects",
